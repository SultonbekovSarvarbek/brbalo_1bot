# Получите новый токен в @BotFather. Не используйте токен, опубликованный в чате.
TELEGRAM_BOT_TOKEN=put_new_token_here

# Необязательно: ограничить работу бота конкретными чатами через запятую.
# ID супергрупп обычно начинается с -100. Пустое значение разрешает все чаты.
ALLOWED_CHAT_IDS=

# Максимум параллельных загрузок и таймаут одной загрузки.
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_TIMEOUT_SECONDS=180

# Официальный Telegram Bot API принимает файлы до 50 МБ.
MAX_FILE_SIZE_MB=49

# Необязательно: Netscape cookies.txt для публикаций, требующих входа.
INSTAGRAM_COOKIES_FILE=
